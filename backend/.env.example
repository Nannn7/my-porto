APP_PORT=8080
# Optional on PaaS platforms like Render/Railway. If set, PORT takes priority over APP_PORT.
PORT=
APP_TLS_ENABLED=false
APP_AUTO_MIGRATE=false
TLS_CERT_PATH=cert/cert.pem
TLS_KEY_PATH=cert/key.pem

# Recommended for managed Postgres providers such as Neon.
DATABASE_URL=

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=myporto
DB_SSLMODE=disable

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me-in-production
ADMIN_SESSION_TTL_HOURS=24

# Comma-separated list, example:
# CORS_ALLOWED_ORIGINS=https://my-porto.com,https://www.my-porto.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
